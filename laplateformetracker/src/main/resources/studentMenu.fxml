<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="720.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="laplateformetracker.controllers.studentmenu.StudentMenuFXMLController">
  <children>
    <MenuBar VBox.vgrow="NEVER">
      <menus>
        <Menu mnemonicParsing="false" text="Fichier">
          <items>
            <MenuItem fx:id="modifyStudentButton" mnemonicParsing="false" onAction="#handleModifyStudentAction" text="Modifier étudiant" />
                  <MenuItem fx:id="deleteStudentButton" mnemonicParsing="false" onAction="#handleDeleteStudentAction" text="Supprimer étudiant" />
            <SeparatorMenuItem mnemonicParsing="false" />
                  <MenuItem fx:id="addGradeButton" mnemonicParsing="false" onAction="#handleAddGradeAction" text="Ajouter note" />
                  <SeparatorMenuItem mnemonicParsing="false" />
            <MenuItem fx:id="logOutButton" mnemonicParsing="false" onAction="#handleLogOutAction" text="Se déconnecter" />
            <MenuItem fx:id="quitButton" mnemonicParsing="false" onAction="#handleQuitAction" text="Quitter" />
          </items>
        </Menu>
        <Menu mnemonicParsing="false" text="Options">
          <items>
            <MenuItem fx:id="changePasswordButton" mnemonicParsing="false" onAction="#handleChangePasswordAction" text="Changer le mot de passe" />
          </items>
        </Menu>
      </menus>
    </MenuBar>
      <FlowPane prefHeight="200.0" prefWidth="200.0">
         <children>
            <ImageView fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@images/user.png" />
               </image>
               <FlowPane.margin>
                  <Insets left="50.0" />
               </FlowPane.margin>
            </ImageView>
            <VBox alignment="CENTER_LEFT" prefHeight="200.0" prefWidth="122.0" spacing="5.0">
               <children>
                  <Label text="Email :" />
                  <Label text="Prénom :" />
                  <Label text="Nom :" />
                  <Label text="Date de naissance :" />
                  <Label text="Addresse :" />
                  <Label text="Téléphone :" />
                  <Label text="Niveau :" />
                  <Label layoutX="30.0" layoutY="168.0" text="Gestionnaire :" />
               </children>
               <padding>
                  <Insets left="20.0" />
               </padding>
            </VBox>
            <VBox alignment="CENTER_LEFT" prefHeight="200.0" prefWidth="747.0" spacing="5.0">
               <children>
                  <Label fx:id="userEmailLabel" text="StudentModel.infos(2)" />
                  <Label fx:id="userFirstNameLabel" text="StudentModel.infos(4)" />
                  <Label fx:id="userLastNameLabel" prefWidth="321.0" text="StudentModel.infos(5)" />
                  <Label fx:id="userBirthDateLabel" text="StudentModel.infos(6)" />
                  <Label fx:id="userAddressLabel" text="StudentModel.infos(7)" />
                  <Label fx:id="userPhoneLabel" text="StudentModel.infos(8)" />
                  <Label fx:id="userDegreeLabel" text="StudentModel.infos(10)" />
                  <Label fx:id="userManagerLabel" layoutX="30.0" layoutY="168.0" text="StudentModel.infos(1)" />
               </children>
               <padding>
                  <Insets left="20.0" />
               </padding>
            </VBox>
            <Button fx:id="returnButton" alignment="TOP_LEFT" contentDisplay="CENTER" mnemonicParsing="false" onAction="#handleReturnAction" text="Retour">
               <FlowPane.margin>
                  <Insets left="20.0" />
               </FlowPane.margin>
            </Button>
         </children>
      </FlowPane>
      <TableView fx:id="tableGrade">
        <columns>
          <TableColumn fx:id="colId" prefWidth="53.5" style="-fx-alignment: CENTER;" text="ID" />
          <TableColumn fx:id="colDate" prefWidth="309.7143135070801" style="-fx-alignment: CENTER;" text="Date" />
            <TableColumn fx:id="colSkill" minWidth="0.0" prefWidth="209.71432495117188" style="-fx-alignment: CENTER;" text="Matière" />
            <TableColumn fx:id="colGrade" prefWidth="145.71429443359375" style="-fx-alignment: CENTER;" text="Note" />
        </columns>
      </TableView>
  </children>
</VBox>
